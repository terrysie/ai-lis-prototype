{
  "name": "terry-lis-desktop-demo",
  "version": "1.0.0",
  "description": "TERRY-LIS 实验室信息管理系统 Windows 桌面端静态演示原型",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "db:init": "node scripts/db-init.js",
    "db:reset": "node scripts/db-reset.js",
    "db:check": "node scripts/db-check.js",
    "smoke:sample-reception": "node scripts/smoke-sample-reception.js",
    "smoke:result-review": "node scripts/smoke-result-review.js",
    "smoke:critical-values": "node scripts/smoke-critical-values.js",
    "smoke:e2e-workflow": "node scripts/smoke-e2e-workflow.js",
    "smoke:report-output": "node scripts/smoke-report-output.js",
    "smoke:report-publish": "node scripts/smoke-report-publish.js",
    "smoke:system-rules": "node scripts/smoke-system-rules.js",
    "smoke:qc-events": "node scripts/smoke-qc-events.js",
    "smoke:reagent-expiry-alerts": "node scripts/smoke-reagent-expiry-alerts.js",
    "smoke:infectious-alerts": "node scripts/smoke-infectious-alerts.js"
  },
  "build": {
    "appId": "com.terrylis.desktop.demo",
    "productName": "TERRY-LIS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "package.json",
      "database/schema.sql",
      "database/seed.sql",
      "src/database/**/*"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "TERRY-LIS-${version}-Windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TERRY-LIS"
    }
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "sql.js": "^1.13.0"
  }
}
