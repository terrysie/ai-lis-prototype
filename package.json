{
  "name": "terry-lis-desktop-demo",
  "version": "1.0.0",
  "description": "TERRY-LIS 实验室信息管理系统 Windows 桌面端静态演示原型",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "db:init": "node scripts/db-init.js",
    "db:reset": "node scripts/db-reset.js",
    "db:check": "node scripts/db-check.js"
  },
  "build": {
    "appId": "com.terrylis.desktop.demo",
    "productName": "TERRY-LIS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "package.json",
      "database/schema.sql",
      "database/seed.sql",
      "src/database/**/*"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "TERRY-LIS-${version}-Windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TERRY-LIS"
    }
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "sql.js": "^1.13.0"
  }
}
